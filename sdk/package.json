{
  "name": "@apoa/core",
  "version": "0.1.2",
  "description": "The reference implementation for the Agentic Power of Attorney standard",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "apoa",
    "authorization",
    "agent",
    "power-of-attorney",
    "delegation",
    "jwt",
    "security",
    "ai-agents",
    "audit-trail",
    "revocation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/agenticpoa/apoa.git",
    "directory": "sdk"
  },
  "homepage": "https://github.com/agenticpoa/apoa",
  "bugs": {
    "url": "https://github.com/agenticpoa/apoa/issues"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "jose": "^6.0.11"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
